datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  email          String   @unique
  password       String?  // nullable — Google users have no password
  googleId       String?  @unique
  avatar         String?  // Google profile picture URL
  internetYear   Int      // the year they started using the internet
  bio            String?
  passportColor  String   @default("indigo")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  flights    Flight[]
  following  Follow[]   @relation("Follower")
  followers  Follow[]   @relation("Following")
  reactions  Reaction[]
  comments   Comment[]
}

model Platform {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  color       String   // primary hex color
  gradient    String   // tailwind gradient classes e.g. "from-pink-500 to-purple-600"
  emoji       String
  description String?
  order       Int      @default(0)

  fromFlights Flight[] @relation("FromPlatform")
  toFlights   Flight[] @relation("ToPlatform")
}

model Flight {
  id           String   @id @default(cuid())
  flightNumber String   @unique
  userId       String
  fromId       String
  toId         String
  reason       String?
  createdAt    DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  from      Platform   @relation("FromPlatform", fields: [fromId], references: [id])
  to        Platform   @relation("ToPlatform", fields: [toId], references: [id])
  reactions Reaction[]
  comments  Comment[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  userId    String
  flightId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  flight Flight @relation(fields: [flightId], references: [id], onDelete: Cascade)

  @@unique([flightId, userId, emoji])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  userId    String
  flightId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  flight Flight @relation(fields: [flightId], references: [id], onDelete: Cascade)
}
